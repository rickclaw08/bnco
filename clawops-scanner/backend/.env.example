# ClawOps Scanner Backend

## Environment Variables

# Required
OPENAI_API_KEY=your_openai_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Optional
PORT=8080
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=https://theclawops.com
REDIS_URL=redis://localhost:6379
OPENAI_GEO_MODEL=gpt-4o-mini
MEO_EXPLAIN_CACHE_TTL_MS=1800000
