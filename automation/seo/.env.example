# SEO Monitoring System - Environment Variables
# Copy this to .env and fill in your values

# Brave Search API (used by all modules for web searches)
# Get a key at: https://api.search.brave.com/
BRAVE_API_KEY=

# Google Search Console API (used by rank-monitor.js)
# Option A: Service account JSON key file path
GSC_SERVICE_ACCOUNT_KEY=

# Option B: Service account credentials as env vars
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=

# Option C: OAuth2 credentials
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# Moz API (optional, for domain authority lookups in backlink-scanner.js)
MOZ_API_KEY=

# Business Information (used by citation-tracker.js)
BUSINESS_PHONE=
BUSINESS_EMAIL=
BUSINESS_ADDRESS=
BUSINESS_CITY=
BUSINESS_STATE=
BUSINESS_ZIP=
BUSINESS_COUNTRY=US
