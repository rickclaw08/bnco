# ============================================================================
# TokenTether - Environment Configuration
# ============================================================================
#
# Copy this file to .env and customize for your setup.
# Every value below is the default - only change what you need.
#
# IMPORTANT: Never commit your .env file. It stays local.
# ============================================================================

# ---------------------------------------------------------------------------
# NETWORK
# ---------------------------------------------------------------------------

# Port TokenTether listens on. Point your OpenClaw clients here instead of
# connecting directly to the gateway.
TT_PROXY_PORT=18788

# OpenClaw gateway host and port. This is where TokenTether forwards traffic.
# If OpenClaw runs on the same machine, use 127.0.0.1.
TT_GATEWAY_HOST=127.0.0.1
TT_GATEWAY_PORT=18789

# ---------------------------------------------------------------------------
# SPENDING LIMITS
# ---------------------------------------------------------------------------

# Hard spending limit in USD. When total spending in the current period hits
# this number, ALL new sessions are blocked (or just warned, depending on
# TT_LIMIT_ACTION). This is your "oh crap" safety net.
TT_HARD_LIMIT_USD=50.00

# Per-session spending limit in USD. If a single session (one WebSocket
# connection) exceeds this, it gets killed immediately. Protects against
# runaway loops in a single agent session.
TT_SESSION_LIMIT_USD=10.00

# Per-model spending limit (0 = disabled). Optional extra guard if you want
# to cap spending on expensive models specifically.
TT_MODEL_LIMIT_USD=0

# Warning threshold as a decimal (0.0 to 1.0). An alert fires when spending
# crosses this percentage of the hard limit. Default 0.80 = 80%.
TT_WARN_THRESHOLD_PCT=0.80

# ---------------------------------------------------------------------------
# RESET INTERVAL
# ---------------------------------------------------------------------------

# How often to reset the spending counters. Options:
#   "1h"    - every hour
#   "24h"   - every 24 hours (daily)
#   "7d"    - every 7 days (weekly)
#   "30d"   - every 30 days (monthly)
#   "never" - never auto-reset (manual only)
TT_RESET_INTERVAL=24h

# ---------------------------------------------------------------------------
# ALERTS - Webhook
# ---------------------------------------------------------------------------

# Webhook URL for alerts. Works with Slack, Discord, or any HTTP endpoint
# that accepts JSON POST requests. Leave empty to disable.
# Slack:   https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Discord: https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
TT_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# ALERTS - Email
# ---------------------------------------------------------------------------

# SMTP configuration for email alerts. All four fields must be set to enable
# email notifications. Uses TLS by default (port 587) or SSL (port 465).
TT_SMTP_HOST=
TT_SMTP_PORT=587
TT_SMTP_USER=
TT_SMTP_PASS=

# Email address to send alerts to.
TT_ALERT_EMAIL=

# ---------------------------------------------------------------------------
# ALERTS - File
# ---------------------------------------------------------------------------

# Directory to write alert JSON files. Useful for integrating with monitoring
# systems or custom scripts that watch a directory. Leave empty to disable.
TT_ALERT_DIR=

# ---------------------------------------------------------------------------
# DASHBOARD
# ---------------------------------------------------------------------------

# Enable/disable the web dashboard. Default: true.
TT_DASHBOARD_ENABLED=true

# Port for the dashboard web UI. Access at http://localhost:18790
TT_DASHBOARD_PORT=18790

# ---------------------------------------------------------------------------
# PERSISTENCE
# ---------------------------------------------------------------------------

# File path to save usage state. Survives restarts so your spending counter
# doesn't reset when TokenTether restarts.
TT_STATE_FILE=./data/usage-state.json

# ---------------------------------------------------------------------------
# BEHAVIOR
# ---------------------------------------------------------------------------

# What happens when the hard limit is reached:
#   "block" - Reject all new sessions (recommended)
#   "warn"  - Log a warning but allow sessions to continue
TT_LIMIT_ACTION=block

# Log level: debug, info, warn, error
TT_LOG_LEVEL=info

# Passthrough mode: monitor and log only, never block or kill sessions.
# Useful for testing before going live. Set to "true" to enable.
TT_PASSTHROUGH=false

# ---------------------------------------------------------------------------
# MODEL PRICING (Advanced)
# ---------------------------------------------------------------------------

# Override default model pricing with a JSON string. Format:
# {"model-name": {"input": cost_per_1k_tokens, "output": cost_per_1k_tokens}}
# Example: {"my-custom-model": {"input": 0.01, "output": 0.03}}
# MODEL_PRICING_JSON=
