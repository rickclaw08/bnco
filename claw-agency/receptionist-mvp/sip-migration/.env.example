# Environment variables for ClawOps AI Receptionist - SIP Connector Architecture
# Copy this file to .env and fill in your values

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_WEBHOOK_SECRET=whsec_your-webhook-secret
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=coral

# Server
PORT=8080
NODE_ENV=development

# NOTE: Twilio credentials are no longer needed in the server.
# Twilio SIP Trunk configuration is done entirely in the Twilio Console.
# The SIP Trunk routes calls directly to OpenAI's SIP endpoint.
